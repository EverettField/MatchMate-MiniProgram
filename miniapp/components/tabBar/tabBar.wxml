<!-- components/tabBar/tabBar.wxml -->
<view class="tab-bar">
  <view 
    class="tab-item {{current === 0 ? 'active' : ''}}" 
    bindtap="onTap" 
    data-index="0"
  >
    <text class="tab-icon">🔍</text>
    <text class="tab-text">探索</text>
  </view>
  
  <view 
    class="tab-item {{current === 1 ? 'active' : ''}}" 
    bindtap="onTap" 
    data-index="1"
  >
    <text class="tab-icon">➕</text>
    <text class="tab-text">发布</text>
  </view>
  
  <view 
    class="tab-item {{current === 2 ? 'active' : ''}}" 
    bindtap="onTap" 
    data-index="2"
  >
    <text class="tab-icon">👤</text>
    <text class="tab-text">我的</text>
  </view>
</view>
