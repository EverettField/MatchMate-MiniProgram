<!-- pages/teamDetail/teamDetail.wxml -->
<view class="page">


  <scroll-view class="content" scroll-y="true" scroll-with-animation="true">
    <view class="card detail-card" wx:if="{{team}}">
      <text class="project-title">{{team.projectName}}{{team.title ? ' ' + team.title : ''}}</text>
      <view class="tag-row" wx:if="{{team.tags && team.tags.length}}">
        <block wx:for="{{team.tags}}" wx:key="{{index}}">
          <text class="tag">{{item}}</text>
        </block>
      </view>
      <view class="tag-row" wx:if="{{!team.tags || !team.tags.length}}">
        <block wx:for="{{team.skills}}" wx:key="{{index}}">
          <text class="tag">{{item}}</text>
        </block>
      </view>

      <view class="status-panel">
        <view class="status-item">
          <text class="status-label">需要人数</text>
          <text class="status-value">{{team.maxNum}}人</text>
        </view>
        <view class="divider"></view>
        <view class="status-item">
          <text class="status-label">已有人数</text>
          <text class="status-value">{{team.currentNum}}人</text>
        </view>
        <view class="divider"></view>
        <view class="status-item">
          <text class="status-label">匹配度</text>
          <text class="status-value status-value-highlight">{{team.matchPercentage || 0}}%</text>
        </view>
      </view>

      <view class="creator-card">
        <image class="avatar" src="{{team.creatorAvatar || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="creator-info">
          <text class="creator-name">{{team.creator}}</text>
          <text class="creator-meta">{{team.school}}{{team.grade ? ' · ' + team.grade : ''}}{{team.gpa ? ' · ' + team.gpa : ''}}</text>
        </view>
      </view>
    </view>

    <view class="card desc-card" wx:if="{{team}}">
      <text class="section-title">项目描述</text>
      <view class="paragraph">{{team.description}}</view>
      <view class="paragraph" wx:if="{{team.requirements}}">{{team.requirements}}</view>
    </view>

    <view class="card footer-card" wx:if="{{team}}">
      <view class="footer-row">
        <view class="footer-item">
          <text class="footer-label">发布时间</text>
          <text class="footer-value">{{team.createTime}}</text>
        </view>
        <view class="footer-item">
          <text class="footer-label">浏览量</text>
          <text class="footer-value">{{team.views || 0}}次</text>
        </view>
      </view>
      <text class="apply-note">“加入队伍需通过发布者审核”</text>
      <button class="btn-action" bindtap="onCopyContact">复制微信号并申请</button>
    </view>

    <view class="empty-state" wx:if="{{!team}}">
      <text class="empty-icon">🔍</text>
      <text class="empty-text">未找到该组队信息</text>
      <button class="btn-back" bindtap="goBack">返回首页</button>
    </view>
  </scroll-view>
</view>