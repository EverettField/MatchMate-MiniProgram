/* pages/teamDetail/teamDetail.wxss */
.page {
  min-height: 100vh;
  background: #eef2f7;
}

.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx 14rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
}

.back-icon {
  font-size: 44rpx;
  color: #243145;
}

.page-title {
  font-size: 32rpx;
  color: #243145;
  font-weight: 700;
}

.topbar-placeholder {
  width: 44rpx;
}

.content {
  padding: 0 24rpx 40rpx;
}

.detail-card {
  margin-top: 18rpx;
  padding: 30rpx;
}

.desc-card,
.footer-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 30rpx;
  margin-top: 18rpx;
}

.project-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #1f2c4b;
  line-height: 1.2;
  margin-bottom: 24rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-bottom: 26rpx;
}

.tag {
  padding: 14rpx 20rpx;
  background: #eff7f4;
  color: #3e8d72;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.status-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f7fbff;
  border-radius: 24rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 28rpx;
}

.status-item {
  flex: 1;
  text-align: center;
}

.status-label {
  display: block;
  font-size: 24rpx;
  color: #8c97b8;
  margin-bottom: 14rpx;
}

.status-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #243145;
}

.status-value-highlight {
  color: #1bbf74;
}

.divider {
  width: 1rpx;
  background: #dce3f1;
  height: 72rpx;
  margin: 0 10rpx;
}

.creator-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
  background: #f8fafc;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-top: 20rpx;
}

.avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: #e9eef8;
}

.creator-info {
  flex: 1;
}

.creator-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a2538;
  margin-bottom: 12rpx;
}

.creator-meta {
  font-size: 26rpx;
  color: #6d758f;
  line-height: 1.5;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2c4b;
  margin-bottom: 22rpx;
}

.paragraph {
  font-size: 28rpx;
  color: #414a66;
  line-height: 1.8;
  margin-bottom: 20rpx;
  white-space: pre-wrap;
}

.footer-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 26rpx;
}

.footer-item {
  flex: 1;
}

.footer-label {
  display: block;
  font-size: 24rpx;
  color: #8c97b8;
  margin-bottom: 12rpx;
}

.footer-value {
  font-size: 28rpx;
  color: #1f2c4b;
}

.apply-note {
  font-size: 24rpx;
  color: #ff7a83;
  text-align: center;
  margin-bottom: 24rpx;
}

.btn-action {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #ff5b61 0%, #ff7a83 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
}

.empty-state {
  text-align: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.btn-back {
  width: 300rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.btn-back::after {
  border: none;
}