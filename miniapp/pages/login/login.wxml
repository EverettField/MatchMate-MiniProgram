<!-- pages/login/login.wxml -->
<view class="page">
  <view class="auth-header">
    <text class="title">校园组队</text>
    <text class="subtitle">找到志同道合的伙伴</text>
  </view>

  <view class="auth-card card">
    <view class="input-group">
      <text class="input-label">用户名</text>
      <input 
        class="input" 
        placeholder="请输入用户名" 
        value="{{username}}"
        bindinput="onInputUsername"
      />
    </view>
    
    <view class="input-group">
      <text class="input-label">密码</text>
      <input 
        class="input" 
        type="password" 
        placeholder="请输入密码" 
        value="{{password}}"
        bindinput="onInputPassword"
      />
    </view>

    <button class="common-btn common-btn-primary" bindtap="doLogin">登 录</button>
    <button class="common-btn common-btn-secondary" bindtap="doRegister">注 册</button>
  </view>
</view>
