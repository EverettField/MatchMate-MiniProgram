/* pages/teamCreate/teamCreate.wxss */
.page {
  min-height: 100vh;
  background: #eef2f7;
}

.header {
  height: 110rpx;
  padding: 24rpx 28rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.header-icon {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 36rpx;
  color: #8f9bb3;
}

.header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2b3348;
}

.header-placeholder {
  width: 60rpx;
  height: 60rpx;
}

.page-body {
  padding: 0 24rpx 40rpx;
}

.card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 30rpx 24rpx 36rpx;
  box-shadow: 0 14rpx 30rpx rgba(92, 108, 138, 0.08);
}

.field {
  margin-bottom: 28rpx;
}

.field:last-child {
  margin-bottom: 0;
}

.field-label {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 18rpx;
}

.field-title {
  font-size: 28rpx;
  color: #394b74;
  font-weight: 600;
}

.field-subtitle {
  font-size: 24rpx;
  color: #9aa3bc;
}

.input,
.textarea {
  width: 100%;
  background: #f7f8fa;
  border-radius: 24rpx;
  border: none;
  padding: 24rpx 22rpx;
  font-size: 28rpx;
  color: #2f3956;
}

.input {
  height: 96rpx;
}

.textarea {
  min-height: 220rpx;
  line-height: 1.8;
  resize: none;
}

.skill-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.skill-tag {
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  border: 1rpx solid #d9dfea;
  background: #f7f8fa;
  color: #5d6d92;
  font-size: 26rpx;
}

.skill-tag-active {
  border-color: #5b7dff;
  background: #eef2ff;
  color: #3850d0;
}

.count-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.count-control {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.stepper-btn {
  width: 68rpx;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 50%;
  background: #f5f7fb;
  color: #3c5dc9;
  font-size: 38rpx;
  text-align: center;
}

.stepper-num {
  min-width: 86rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2a44;
}

.actions {
  margin-top: 30rpx;
}

.btn-primary {
  width: 100%;
  height: 108rpx;
  line-height: 108rpx;
  border-radius: 54rpx;
  background: linear-gradient(135deg, #5d7dff 0%, #7b5ce5 100%);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
}

.modal-dialog {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 676rpx;
  max-width: 90%;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 34rpx 28rpx;
  z-index: 1001;
  box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.18);
}

.modal-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2c4b;
  margin-bottom: 24rpx;
}

.modal-input {
  width: 100%;
  height: 96rpx;
  padding: 0 26rpx;
  font-size: 28rpx;
  color: #243145;
  background: #f7f8fa;
  border-radius: 24rpx;
  border: none;
}

.modal-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 30rpx;
}

.modal-btn {
  flex: 1;
  height: 92rpx;
  border-radius: 46rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.modal-btn.cancel {
  background: #f3f4f9;
  color: #5f6d8b;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #5d7dff 0%, #7b5ce5 100%);
  color: #ffffff;
}
