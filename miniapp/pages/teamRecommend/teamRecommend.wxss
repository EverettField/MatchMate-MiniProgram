/* pages/teamRecommend/teamRecommend.wxss */
.page {
  min-height: 100vh;
  background: #eef2f7;
}

.container {
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.top-panel {
  padding: 44rpx 28rpx 18rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e2538;
  margin-bottom: 24rpx;
  text-align: center;
}

.search-bar {
  background: #ffffff;
  border-radius: 34rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.08);
}

.search-box {
  display: flex;
  align-items: center;
  background: #f0f2f8;
  border-radius: 32rpx;
  padding: 18rpx 24rpx;
}

.search-icon {
  font-size: 34rpx;
  margin-right: 18rpx;
}

.search-input {
  flex: 1;
  height: 48rpx;
  font-size: 30rpx;
  color: #334155;
  background: transparent;
}

.type-filter {
  padding: 20rpx 18rpx 16rpx;
}

.type-item {
  display: inline-block;
  padding: 16rpx 32rpx;
  margin-right: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e8ecf4;
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #64748b;
}

.type-item.active {
  background: #eef2ff;
  border-color: #667eea;
  color: #334155;
}

.team-list {
  padding: 0 20rpx 180rpx;
}

.team-card {
  background: #ffffff;
  border-radius: 30rpx;
  padding: 32rpx 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(102, 126, 234, 0.12);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.3;
  width: 72%;
}

.match-badge {
  background: #ecfdf5;
  color: #16a34a;
  font-size: 24rpx;
  font-weight: 600;
  padding: 12rpx 20rpx;
  border-radius: 24rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx 14rpx;
  margin-bottom: 24rpx;
}

.tag-item {
  background: #f8fafc;
  color: #475569;
  font-size: 24rpx;
  padding: 10rpx 18rpx;
  border-radius: 20rpx;
}

.card-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.avatar {
  width: 70rpx;
  height: 70rpx;
  background: #eef2ff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.meta-text {
  flex: 1;
  margin-left: 20rpx;
}

.creator {
  display: block;
  font-size: 28rpx;
  color: #0f172a;
  font-weight: 600;
}

.school {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.meta-arrow {
  font-size: 32rpx;
  color: #667eea;
}

.empty-state {
  text-align: center;
  padding: 180rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 40rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #94a3b8;
  margin-bottom: 60rpx;
}

.btn-create {
  width: 330rpx;
  height: 88rpx;
  background: #667eea;
  color: #ffffff;
  border-radius: 44rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-create::after {
  border: none;
}
