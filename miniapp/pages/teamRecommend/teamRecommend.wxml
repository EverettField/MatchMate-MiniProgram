<!-- pages/teamRecommend/teamRecommend.wxml -->
<view class="page container">
  <view class="top-panel">
    <text class="page-title">组队推荐</text>
    <view class="search-bar">
      <view class="search-box">
        <text class="search-icon"></text>
        <input
          class="search-input"
          placeholder="搜索项目、技能或同学"
          value="{{searchKeyword}}"
          bindinput="onSearch"
        />
      </view>
    </view>
  </view>

  <scroll-view class="type-filter" scroll-x>
    <view
      class="type-item {{typeIndex === index ? 'active' : ''}}"
      wx:for="{{typeFilters}}"
      wx:key="index"
      bindtap="onTypeChange"
      data-index="{{index}}"
    >
      {{item}}
    </view>
  </scroll-view>

  <scroll-view class="team-list" scroll-y>
    <view
      class="team-card"
      wx:for="{{filteredTeams}}"
      wx:key="id"
      bindtap="goToDetail"
      data-id="{{item.id}}"
    >
      <view class="card-top">
        <text class="card-title">{{item.title}}</text>
        <view class="match-badge">{{item.matchPercentage}}% 匹配</view>
      </view>

      <view class="tag-list">
        <view class="tag-item" wx:for="{{item.tags}}" wx:key="*this">{{item}}</view>
      </view>

      <view class="card-meta">
        <view class="avatar">👤</view>
        <view class="meta-text">
          <text class="creator">{{item.creator}}</text>
          <text class="school">{{item.school}}</text>
        </view>
        <text class="meta-arrow">〉</text>
      </view>
    </view>

    <view class="empty-state" wx:if="{{filteredTeams.length === 0 && !isLoading}}">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无相关组队信息</text>
      <button class="btn-create" bindtap="goToCreate">去发布</button>
    </view>
  </scroll-view>

  <tab-bar current="0"></tab-bar>
</view>
