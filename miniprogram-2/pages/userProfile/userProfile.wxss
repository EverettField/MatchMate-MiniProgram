/* pages/userProfile/userProfile.wxss */
.page {
  min-height: 100vh;
  background: #f4f5f8;
  padding-bottom: 140rpx;
}

.profile-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 10rpx 24rpx 10rpx;
}

.screen-title {
  font-size: 45rpx;
  font-weight: 900;
  color: #1d2334;
}

.progress-text {
  font-size: 28rpx;
  color: #99a2b6;
}

.content {
  background: #f4f5f8;
  padding: 0rpx;
}

.card {
  background: #ffffff;
  border-radius: 34rpx;
  padding: 28rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 14rpx 36rpx rgba(36, 63, 115, 0.08);
}

.profile-card {
  padding-bottom: 24rpx;
}

.profile-card-top {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 22rpx;
}

.avatar-wrap {
  position: relative;
  width: 124rpx;
  height: 124rpx;
  flex-shrink: 0;
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 6rpx solid #1f1f1f;
  box-shadow: 0 20rpx 52rpx rgba(42, 91, 160, 0.12);
  background: #eef2f7;
}

.avatar-badge {
  position: absolute;
  right: -4rpx;
  bottom: -4rpx;
  width: 54rpx;
  height: 54rpx;
  background: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 24rpx rgba(45, 74, 116, 0.14);
}

.badge-icon {
  width: 28rpx;
  height: 28rpx;
}

.profile-info {
  flex: 1;
}

.label-secondary {
  display: inline-block;
  font-size: 24rpx;
  color: #94a3b8;
  margin-bottom: 5rpx;
}

.profile-name {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #1e2839;
  line-height: 1.2;
  margin-bottom: 10rpx;
}

.profile-school {
  font-size: 26rpx;
  color: #8b97ab;
  margin-bottom: 10rpx;
}

.profile-card-divider {
  height: 1rpx;
  background: #eef0f5;
  margin-bottom: 20rpx;
}

.profile-card-body {
  display: flex;
  gap: 18rpx;
}

.field-item {
  flex: 1;
}

.compact-field {
  background: #f9fbff;
  border-radius: 30rpx;
  padding: 22rpx 18rpx;
}

.field-label {
  display: block;
  font-size: 24rpx;
  color: #224183;
  margin-bottom: 14rpx;
}

.field-value,
.field-input {
  width: 89%;
  min-height: 86rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e7eef8;
  font-size: 28rpx;
  color: #243145;
  padding: 0 20rpx;
  margin-left: -10rpx;
  line-height: 86rpx;
  box-sizing: overflow-box;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.field-input {
  color: #818181;
}

.tag-card,
.schedule-card {
  padding-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  color: #151f34;
  font-weight: 800;
  margin-bottom: 20rpx;
}

.skill-wrap {
  margin-top: 15rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.skill-pill {
  padding: 12rpx 26rpx;
  border-radius: 9999rpx;
  font-size: 26rpx;
  color: #6d7790;
  background: #f3f5ff;
  border: 1rpx solid #e3e8fb;
}

.skill-pill-active {
  background: #1bc361;
  color: #ffffff;
  border-color: transparent;
}

.skill-pill-add {
  color: #a7afc6;
}

.schedule-table {
  margin-top: 12rpx;
  display: grid;
  gap: 10rpx;
}

.schedule-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.header-row {
  margin-bottom: 10rpx;
}

.schedule-cell {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #6d7790;
}

.header-cell,
.label-cell {
  width: 100rpx;
  min-width: 100rpx;
  height: 76rpx;
  border-radius: 20rpx;
  background: transparent;
}

.day-cell {
  flex: 1;
  height: 76rpx;
  background: #f3f6ff;
  border-radius: 15rpx;
}
