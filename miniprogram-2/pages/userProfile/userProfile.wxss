.day-cell.day-full {
  background: linear-gradient(135deg, #1fe7ae 0%, #48ff79 100%);
  color: #fff;
  font-weight: bold;
} */

.slot-cell {
  flex: 1;
  
  height: 70rpx;
  border-radius: 20rpx;
  background: #f3f6ff;
}

.slot-active {
 background: #40dd7f;
}

.schedule-note {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #98a4b8;
}

.actions {
  margin: 0 0 32rpx;
}

.btn-submit {
  width: 100%;
  height: 108rpx;
  border-radius: 45rpx;
  font-size: 34rpx;
  letter-spacing: 2rpx;
}

/* 新加-我的组队入口 */
.my-team-card {
  padding: 24rpx;
}
.tubiao{
  float: right;
  margin-right: 20rpx;
}
.team-entry {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, #f8f5ff 0%, #f0f5fc 100%);
  border-radius: 24rpx;
  margin-top: 8rpx;
}

.team-entry-text {
  font-size: 28rpx;
  color: #4a5568;
}

.team-entry-arrow {
  font-size: 32rpx;
  color: #a0aec0;
}
