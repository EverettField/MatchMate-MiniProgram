<view class="page container">
 

  <view class="tab-bar">
    <view 
      class="tab-item {{activeTab === 0 ? 'active' : ''}}" 
      data-index="0" 
      bindtap="onTabChange"
    >
      全部
      <view class="tab-count">{{myTeams.length}}</view>
    </view>
    <view 
      class="tab-item {{activeTab === 1 ? 'active' : ''}}" 
      data-index="1" 
      bindtap="onTabChange"
    >
      我创建的
      <view class="tab-count">{{createdTeams.length}}</view>
    </view>
    <view 
      class="tab-item {{activeTab === 2 ? 'active' : ''}}" 
      data-index="2" 
      bindtap="onTabChange"
    >
      我加入的
      <view class="tab-count">{{joinedTeams.length}}</view>
    </view>
  </view>

  <scroll-view class="team-list" scroll-y>
    <block wx:if="{{activeTab === 0}}">
      <view 
        class="team-card" 
        wx:for="{{myTeams}}" 
        wx:key="id"
        bindtap="goToDetail" 
        data-id="{{item.id}}"
      >
        <view class="card-header">
          <text class="card-title">{{item.title}}</text>
          <view class="status-badge {{item.isCreator ? 'creator' : 'joined'}}">
            {{item.isCreator ? '我创建' : '已加入'}}
          </view>
        </view>

        <view class="tag-list">
          <view class="tag-item">{{item.category}}</view>
        </view>

        <view class="card-footer">
          <view class="meta-info">
            <!-- <text class="creator-text">发布者：{{item.creator}}</text> -->
          </view>
          <view class="action-btn offshelf-btn" wx:if="{{item.isCreator}}" catchtap="onOffShelf" data-id="{{item.id}}">
            下架
          </view>
          <view class="action-btn" wx:if="{{!item.isCreator}}" catchtap="onQuitTeam" data-id="{{item.id}}">
            退出
          </view>
        </view>
      </view>
    </block>

    <block wx:if="{{activeTab === 1}}">
      <view 
        class="team-card" 
        wx:for="{{createdTeams}}" 
        wx:key="id"
        bindtap="goToDetail" 
        data-id="{{item.id}}"
      >
        <view class="card-header">
          <text class="card-title">{{item.title}}</text>
          <view class="status-badge creator">我创建</view>
        </view>

        <view class="tag-list">
          <view class="tag-item">{{item.category}}</view>
        </view>

        <view class="card-footer">
          <view class="meta-info">
            <!-- <text class="creator-text">发布者：{{item.creator}}</text> -->
          </view>
          <view class="action-btn offshelf-btn" catchtap="onOffShelf" data-id="{{item.id}}">
            下架
          </view>
        </view>
      </view>
    </block>

    <block wx:if="{{activeTab === 2}}">
      <view 
        class="team-card" 
        wx:for="{{joinedTeams}}" 
        wx:key="id"
        bindtap="goToDetail" 
        data-id="{{item.id}}"
      >
        <view class="card-header">
          <text class="card-title">{{item.title}}</text>
          <view class="status-badge joined">已加入</view>
        </view>

        <view class="tag-list">
          <view class="tag-item">{{item.category}}</view>
        </view>

        <view class="card-footer">
          <view class="meta-info">
            <!-- <text class="creator-text">发布者：{{item.creator}}</text> -->
          </view>
          <view class="action-btn" catchtap="onQuitTeam" data-id="{{item.id}}">
            退出
          </view>
        </view>
      </view>
    </block>

    <view class="empty-state" wx:if="{{myTeams.length === 0 && activeTab === 0 && !isLoading}}">
      <image class="empty-icon" src="/images/empty.svg" mode="aspectFit" />
      <text class="empty-text">{{emptyText}}</text>
      <button class="btn-create" bindtap="goToCreate">去发布</button>
    </view>
    <view class="empty-state" wx:if="{{createdTeams.length === 0 && activeTab === 1 && !isLoading}}">
      <image class="empty-icon" src="/images/empty.svg" mode="aspectFit" />
      <text class="empty-text">{{emptyText}}</text>
      <button class="btn-create" bindtap="goToCreate">去发布</button>
    </view>
    <view class="empty-state" wx:if="{{joinedTeams.length === 0 && activeTab === 2 && !isLoading}}">
      <image class="empty-icon" src="/images/empty.svg" mode="aspectFit" />
      <text class="empty-text">{{emptyText}}</text>
      <button class="btn-create" bindtap="goToCreate">去发布</button>
    </view>
  </scroll-view>
</view>
