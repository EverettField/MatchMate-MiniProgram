<!-- pages/teamCreate/teamCreate.wxml -->
<view class="page">
  <!-- <view class="header">
    <image class="header-icon" bindtap="onClose" src="/images/close.svg" mode="aspectFit" />
    <text class="header-title">发布新组队</text>
    <view class="header-placeholder"></view>
  </view> -->

  <view class="page-body">
    <view class="card">
      <view class="field">
        <text class="field-title">组队类型</text>
        <view class="type-selector">
          <view class="type-item {{type === 'contest' ? 'type-item-active' : ''}}" bindtap="onSelectType" data-type="contest">
        
            <text class="type-text">竞赛组队</text>
          </view>
          <view class="type-item {{type === 'course' ? 'type-item-active' : ''}}" bindtap="onSelectType" data-type="course">
         
            <text class="type-text">课业组队</text>
          </view>
        </view>
      </view>

      <view class="field">
        <view class="field-label">
          <text class="field-title">招募标题</text>
          <text class="field-subtitle">例：寻找数学建模大赛队友</text>
        </view>
        <input
          class="input"
          value="{{recruitTitle}}"
          placeholder="请输入招募标题"
          placeholder-style="color:#c8c9d3"
          data-field="recruitTitle"
          bindinput="onInput"
        />
      </view>

      <view class="field">
        <text class="field-title">项目名称</text>
        <input
          class="input"
          value="{{projectName}}"
          placeholder="具体项目或比赛名称"
          placeholder-style="color:#c8c9d3"
          data-field="projectName"
          bindinput="onInput"
        />
      </view>

      <view class="field">
        <text class="field-title">项目描述</text>
        <textarea
          class="textarea"
          value="{{projectDescription}}"
          placeholder="详细描述一下你的项目目标、目前进展以及你对队友的期待…"
          placeholder-style="color:#c8c9d3"
          data-field="projectDescription"
          bindinput="onInput"
        />
      </view>

      <view class="field">
        <view class="field-label">
          <text class="field-title">所需技能（多选）</text>
        </view>
        <view class="skill-list">
          <block wx:for="{{skills}}" wx:key="name">
            <view
              class="skill-tag {{item.selected ? 'skill-tag-active' : ''}}"
              data-index="{{index}}"
              bindtap="onToggleSkill"
            >
              {{item.name}}
            </view>
          </block>
        </view>
      </view>

      <view class="field count-field">
        <text class="field-title">需要人数</text>
        <view class="count-control">
          <view class="stepper-btn" bindtap="onAdjustNum" data-type="sub">-</view>
          <text class="stepper-num">{{needNum}}</text>
          <view class="stepper-btn" bindtap="onAdjustNum" data-type="add">+</view>
        </view>
        
      </view>

      <view class="field">
        <text class="field-title">联系方式（微信号）</text>
        <input
          class="input"
          value="{{contact}}"
          placeholder="输入微信号，仅通过审核者可见"
          placeholder-style="color:#c8c9d3"
          data-field="contact"
          bindinput="onInput"
        />
      </view>
    </view>

    <view class="actions">
      <button class="btn-primary" bindtap="onSubmit">发布组队</button>
    </view>
  </view>

  <tab-bar current="1"></tab-bar>
</view>
