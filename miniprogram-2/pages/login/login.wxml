<!-- pages/login/login.wxml -->
<view class="page">
  <view class="auth-header">
    <text class="title">校园组队</text>
    <text class="subtitle">找到志同道合的伙伴</text>
  </view>
  <!-- 登录卡片 -->
  <view class="login-card">
    <view class="avatar-area">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image 
          class="avatar-img {{avatar ? 'has-avatar' : ''}}" 
          src="{{avatar || '/images/default-avatar.svg'}}" 
          mode="aspectFill"
        />
        <view class="avatar-tip {{avatar ? 'hidden' : ''}}">点击获取用户头像</view>
      </button>
    </view>

    <view class="divider"></view>

    <view class="input-row">
      <text class="input-label">用户名</text>
      <input
        class="nickname-input"
        type="nickname"
        placeholder="请输入用户名"
        value="{{nickname}}"
        bindinput="onInputNickname"
        bindblur="onNicknameBlur"
      />
    </view>

    <button 
      class="login-button {{canLogin ? 'login-button-active' : 'login-button-disabled'}}" 
      open-type="getUserInfo" 
      bindgetuserinfo="onGetUserInfo"
    >微信授权登录</button>
  </view>
</view>
