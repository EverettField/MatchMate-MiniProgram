page, .page, .container {
  min-height: 100vh;
  width: 100%;
  background: #eef2f7;
  box-sizing: border-box;
  color: #243145;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
}

.page {
  padding-bottom: 140rpx;
}

.card {
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 14rpx 30rpx rgba(0, 0, 0, 0.08);
}

.text-muted {
  color: #6b7280;
}

.common-btn {
  width: 100%;
  height: 108rpx;
  border-radius: 54rpx;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.common-btn-primary {
  background: linear-gradient(135deg, #7e80a9 0%, #4f1ad5 100%);
  color: #ffffff;
}

.common-btn-secondary {
  background: #f5f7ff;
  color: #4f5d7a;
}
